# ── Server ────────────────────────────────────────────────────────────────────

PORT=3000

# Comma-separated Bearer tokens for MCP auth. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_KEYS=your-api-key-here

# Public URL of this server — shown in agent responses as the password setup guide.
# Required for the agent to produce the correct curl command.
SERVER_URL=https://your-server.example.com

# ── Database ──────────────────────────────────────────────────────────────────
# Postgres connection string. Works with Neon, Supabase, Railway, AWS RDS,
# self-hosted, or any standard Postgres provider.
# The mail_mcp_accounts table is created automatically on first run.
# Note: remove channel_binding=require if present in the URL (postgres.js
# does not support SCRAM-SHA-256-PLUS).
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Encryption key for passwords at rest (AES-256-GCM).
# Also used as the Bearer token for POST /accounts/:name/password —
# keep this separate from API_KEYS so the agent cannot set passwords.
# Minimum 16 chars. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MAIL_MCP_SECRET=your-encryption-key-here

# ── Default account (optional) ────────────────────────────────────────────────
# Always loaded from env as the "default" account regardless of DB contents.
# Additional accounts are managed via the agent + DB.
# Omit entirely if all accounts are managed through the database.
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_SECURE=true
IMAP_USER=you@gmail.com
IMAP_PASS=your-gmail-app-password

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=you@gmail.com
SMTP_PASS=your-gmail-app-password
